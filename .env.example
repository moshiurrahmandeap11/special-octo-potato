# ====================================================================
# Crowdfunding Platform - Server Environment Variables (EXAMPLE)
# Copy this file to .env and fill in real values.
# ====================================================================

# --- Application ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/crowdfunding
DB_NAME=crowdfunding

# --- JWT ---
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- OpenAI OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/OpenAI

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- imgBB (optional) ---
IMGBB_API_KEY=

# --- Admin Seed Credentials ---
ADMIN_EMAIL=admin@crowdfund.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Platform Admin
ADMIN_PHOTO=https://i.ibb.co/0Q8c0cX/admin.png
DEMO_USER_EMAIL=supporter@crowdfund.com
DEMO_USER_PASSWORD=Supporter@12345

# --- Frontend URL (CORS) ---
CLIENT_URL=http://localhost:3000
